# ddokdak 환경변수 설정 예시
# 이 파일을 .env로 복사한 후 값을 채워 사용하세요.

# [필수] 디스코드 봇 토큰
DISCORD_TOKEN=your-discord-bot-token-here

# [선택] Antigravity CLI 기본 모델 (기본값: Claude Opus 4.6 (Thinking))
# AGY_MODEL=Claude Opus 4.6 (Thinking)

# [선택] 대체 모델 (기본값: Gemini 3.1 Pro (High))
# AGY_FALLBACK_MODEL=Gemini 3.1 Pro (High)

# [선택] agy 명령 타임아웃 (기본값: 5m)
# AGY_TIMEOUT=5m

# [선택] 로그 레벨: debug, info, warn, error (기본값: info)
# LOG_LEVEL=info
